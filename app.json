{
  "expo": {
    "name": "Iron & Metal",
    "slug": "mobile",
    "scheme": "ironmetal",
    "version": "1.0.6",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "NEVER"
    },
    "orientation": "portrait",
    "icon": "./assets/icon/logo6.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon/logo6.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/icon/logo6.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akafi.ironmetal",
      "buildNumber": "19",
      "usesIcloudStorage": false,
      "itsAppUsesNonExemptEncryption": false,
      "associatedDomains": ["applinks:iron-metal.net"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/logo6.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.alabuotrading.ironandmetal",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "bb9dca3c-7b06-473d-a39a-66ebda95f1d5"
      }
    },
    "owner": "mnqwzxp"
  }
}
